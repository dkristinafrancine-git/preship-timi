// Preship — War Room for Alpha Stage Founders
// Prisma schema (PostgreSQL / Supabase)
//
// DATABASE_URL points at the Supabase transaction-mode pooler (PgBouncer)
// used at runtime; DIRECT_URL points at the session-mode pooler used by
// `prisma migrate` (migrations need a real session and cannot run through
// PgBouncer in transaction mode).
//
// NOTE on indexes: the @@index declarations below are Prisma-managed B-tree
// indexes (exact-match + prefix range scans). Leading-wildcard ILIKE search
// (`%term%`) is NOT accelerated by B-tree indexes, so the trigram (pg_trgm)
// GIN indexes that power /api/feed?tag and /api/search live in a raw SQL
// migration (20260621120000_add_trgm_search_indexes) — Prisma can't express
// them. When adding a new ILIKE-searched column, add a matching GIN trigram
// index in a raw migration, not here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---- Core: Founders & Projects ----

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  passwordHash String? // null for demo/seeded users (credentials provider allows email-only)
  handle      String   @unique
  name        String
  title       String   // e.g. "Founder @ Acme", "Solo Builder"
  bio         String?
  location    String?
  avatarUrl   String?
  skills      String?  // comma separated
  bountiesPublic Boolean @default(true) // show gathered bounties on shareable profile
  isCurrent   Boolean  @default(false) // the "logged in" founder in this demo
  // preferences (Settings page)
  prefTheme          String   @default("system") // system | light | dark
  prefNotifications  Boolean  @default(true)
  prefEmailDigest    Boolean  @default(false)
  prefCompactMode    Boolean  @default(false)
  onboarded          Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects           Project[]
  posts              Post[]
  reactions          Reaction[]
  comments           Comment[]
  synergyRequests    SynergyRequest[]
  synergyOffers      SynergyOffer[]
  hostedSessions     IdeaLabSession[]  @relation("SessionHost")
  sessionSignups     IdeaLabSignup[]
  interests          IdeaLabInterest[]
  following          Follow[]           @relation("Follower")
  followers          Follow[]           @relation("Following")
  notifications      Notification[]
  articles           Article[]
  articleClaps       ArticleClap[]
  invitesSent        Invite[]           @relation("InviteSender")
  invitesAccepted    Invite[]           @relation("InviteAcceptor")

  @@index([isCurrent])
  @@index([handle])
  @@index([email])
}

// ---- Invites: a founder emails an invite to a new founder ----

model Invite {
  id           String    @id @default(cuid())
  email        String    // invitee email (lowercased)
  token        String    @unique // opaque token in the signup link
  inviterId    String
  inviter      User      @relation("InviteSender", fields: [inviterId], references: [id], onDelete: Cascade)
  note         String?   // optional personal note from the inviter
  status       String    @default("sent") // sent | accepted
  acceptedById String?
  acceptedBy   User?     @relation("InviteAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([inviterId, email]) // one outstanding invite per (inviter, email)
  @@index([email])
  @@index([token])
  @@index([inviterId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])

  @@index([followerId])
  @@index([followingId])
}

model Project {
  id          String   @id @default(cuid())
  founderId   String
  founder     User     @relation(fields: [founderId], references: [id], onDelete: Cascade)
  name        String
  tagline     String
  description String?
  category    String   // e.g. DevTool, SaaS, Consumer, AI, Marketplace
  alphaStage  String   // Customer Discovery | Problem Validation | Prototyping | Closed Beta | Public Beta | Pre-Launch
  logoUrl     String?  // uploaded logo image (preferred)
  logoColor   String   @default("#DAFF01") // fallback tile color (kept for legacy monogram)
  logoMark    String?  // fallback monogram e.g. "AC"
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts           Post[]
  synergyRequests SynergyRequest[]

  @@index([founderId])
  @@index([alphaStage])
  @@index([category])
}

// ---- Feed: text + audio posts ----

model Post {
  id            String   @id @default(cuid())
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type          String   @default("text") // text | audio
  body          String?
  audioTitle    String?
  audioUrl      String?  // URL to the uploaded audio file (real recording)
  audioDuration Int?     // seconds
  audioWaveform String?  // comma-separated bar heights 0..1
  tags          String?  // comma-separated hashtags
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reactions Reaction[]
  comments  Comment[]

  @@index([authorId, createdAt])
  @@index([projectId])
  @@index([createdAt])
  @@index([type])
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // like | repost | handshake
  createdAt DateTime @default(now())

  @@unique([postId, userId, kind])

  @@index([postId, kind])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([userId])
}

// ---- Synergy: bottleneck broadcast + bounty + handshake ----

model SynergyRequest {
  id             String   @id @default(cuid())
  founderId      String
  founder        User     @relation(fields: [founderId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title          String
  bottleneck     String   // the problem
  need           String   // what kind of help
  bountyType     String   // equity | advisor-shares | revenue-share | cofounder | barter
  stake          Float?   // % stake if equity/advisor
  bountyDetail   String?  // description of the bounty
  tags           String?  // comma-separated
  status         String   @default("open") // open | matched | closed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  offers SynergyOffer[]

  @@index([founderId, createdAt])
  @@index([status, createdAt])
  @@index([projectId])
  @@index([bountyType])
}

model SynergyOffer {
  id         String   @id @default(cuid())
  requestId  String
  request    SynergyRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  founderId  String
  founder    User     @relation(fields: [founderId], references: [id], onDelete: Cascade)
  pitch      String   // why I'm the right match
  offer      String?  // counter-offer / terms
  status     String   @default("pending") // pending | accepted | declined
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([founderId, status])
  @@index([status])
}

// ---- IdeaLab: invite-only live audio ideation ----

model IdeaLabSession {
  id            String   @id @default(cuid())
  title         String
  thesis        String   // the startup idea / hypothesis to explore
  description   String?
  hostId        String
  host          User     @relation("SessionHost", fields: [hostId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  durationMins  Int      @default(60)
  status        String   @default("scheduled") // scheduled | live | ended
  agenda        String?  // newline-separated agenda items
  rolesOpen     String?  // comma-separated open roles (Technical Lead, Design Lead, etc.)
  inviteCode    String   @unique
  maxSeats      Int      @default(8)
  isPublic      Boolean  @default(false) // visible in the public IdeaLab board
  coverColor    String   @default("#0E1909")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  signups   IdeaLabSignup[]
  interests IdeaLabInterest[]

  @@index([hostId, scheduledAt])
  @@index([status])
  @@index([isPublic, scheduledAt])
  @@index([scheduledAt])
}

model IdeaLabSignup {
  id        String   @id @default(cuid())
  sessionId String
  session   IdeaLabSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // host | co-host | technical-lead | design-lead | product-lead | marketing-lead | participant
  status    String   @default("registered") // registered | invited | confirmed | declined
  createdAt DateTime @default(now())

  @@unique([sessionId, userId])

  @@index([sessionId])
  @@index([userId])
}

model IdeaLabInterest {
  id        String   @id @default(cuid())
  sessionId String
  session   IdeaLabSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())

  @@unique([sessionId, userId])

  @@index([sessionId])
  @@index([userId])
}

// ---- Notifications ----

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   // reaction | comment | handshake-offer | offer-accepted | follow | session-starting | session-live | bounty-gathered
  title     String
  body      String
  linkView  String?  // war-room | synergy | idealab | projects | profile
  linkId    String?  // postId / synergyId / sessionId / founderId
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([createdAt])
}

// ---- Brain Dump (articles) ----

model Article {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  subtitle    String?
  body        String   // markdown-ish plain text
  tags        String?  // comma-separated
  published   Boolean  @default(false)
  coverColor  String   @default("#0E1909")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claps ArticleClap[]

  @@index([published, createdAt])
  @@index([authorId, createdAt])
  @@index([createdAt])
}

model ArticleClap {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([articleId, userId])

  @@index([articleId])
  @@index([userId])
}

