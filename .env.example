# ── Database (Supabase Postgres via PgBouncer poolers) ───────────────────────
# DATABASE_URL: transaction-mode pooler (IPv4-only). Used by Prisma Client at
#   runtime. `pgbouncer=true` is required and connection_limit=1 avoids starving
#   the pool under serverless/edge concurrency.
# DIRECT_URL:   session-mode pooler. Used by `prisma migrate` / `prisma db seed`
#   only — migrations cannot run through the transaction pooler.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Storage (file uploads) ──────────────────────────────────────────
# Project URL + service-role key. The service-role key bypasses RLS and is only
# ever used server-side in /api/upload. NEVER expose it to the client.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── LiveKit (IdeaLab live audio rooms) ──────────────────────────────────────
# From your LiveKit Cloud dashboard (or a self-hosted server).
# LIVEKIT_URL is the wss:// endpoint — safe to expose to the client (returned
#   by the token route). The API key/secret sign JWTs server-side only AND
#   verify incoming webhook signatures (see /api/webhooks/livekit).
# To record IdeaLab participant-minutes in the admin console, point LiveKit's
#   webhook URL at <APP_URL>/api/webhooks/livekit in the dashboard.
LIVEKIT_URL="wss://<project>.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# ── Platform admin console ──────────────────────────────────────────────────
# Comma-separated allowlist of emails granted the superadmin role at sign-in
# (see src/lib/admin.ts ensureAdminRole). Leave unset to disable auto-promotion;
# the /admin console is then inaccessible until a row is set to role=superadmin
# directly (e.g. via Prisma Studio).
ADMIN_EMAILS="founder@preship.app"
